{
  "expo": {
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2664b647-4200-4d00-b8bc-e47ddb4cda05"
      },
      "API_BASE_URL": "EXPO_PUBLIC_API_BASE_URL",
      "GOOGLE_CLIENT_ID_ANDROID": "EXPO_PUBLIC_GOOGLE_CLIENT_ID_ANDROID",
      "GOOGLE_EXPO_CLIENT_ID": "EXPO_PUBLIC_GOOGLE_EXPO_CLIENT_ID"
    },
    "name": "frontend",
    "slug": "jex",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "frontend",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "owner": "leofragherazzi",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.jexapp"
    },
    "android": {
      "package": "com.jexapp",
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/jex/Jex-Logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-web-browser",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "owner": "jex-app"
  }
}